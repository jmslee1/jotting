{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "jotting",
  "version": "0.1.0",
  "identifier": "com.jotting.app",
  "build": {
  "beforeDevCommand": "npx vite dev",
  "beforeBuildCommand": "npx vite build",
  "devUrl": "http://localhost:5173",
  "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "jotting",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}